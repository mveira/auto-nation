# ── Supabase / Postgres ──
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# ── Resend (email delivery) ──
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=onboarding@resend.dev
EMAIL_TO=your-email@example.com

# ── Public (safe to expose) — JSON-LD + contact details ──
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_BUSINESS_NAME=Car Nation Services
NEXT_PUBLIC_BUSINESS_PHONE=+441171234567
NEXT_PUBLIC_BUSINESS_STREET=123 Fishponds Road
NEXT_PUBLIC_BUSINESS_CITY=Fishponds, Bristol
NEXT_PUBLIC_BUSINESS_REGION=Bristol
NEXT_PUBLIC_BUSINESS_POSTCODE=BS16 3AN
NEXT_PUBLIC_BUSINESS_COUNTRY=GB
NEXT_PUBLIC_BUSINESS_LAT=51.4752
NEXT_PUBLIC_BUSINESS_LNG=-2.5281
NEXT_PUBLIC_CONTACT_EMAIL=services@carnation.co.uk

# ── DVLA Vehicle Enquiry Service ──
DVLAAPI_KEY=your-dvla-api-key

# ── DVSA MOT History API (server-only, never exposed to browser) ──
DVSA_API_KEY=your-dvsa-api-key
DVSA_CLIENT_ID=your-client-id
DVSA_CLIENT_SECRET=your-client-secret
DVSA_TOKEN_URL=https://login.microsoftonline.com/YOUR_TENANT/oauth2/v2.0/token
DVSA_SCOPE=https://tapi.dvsa.gov.uk/.default
DVSA_ENABLED=true

# ── GoHighLevel Private Integration (API-based sync) ──
GHL_PRIVATE_KEY=pit-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GHL_LOCATION_ID=your-location-id
GHL_PIPELINE_ID=your-pipeline-id
GHL_STAGE_ID_NEW=your-new-stage-id

# ── GoHighLevel CRM webhooks (legacy fallback — optional) ──
GHL_WEBHOOK_BOOK_URL=https://services.leadconnectorhq.com/hooks/YOUR_BOOKING_HOOK_ID
GHL_WEBHOOK_CONTACT_URL=https://services.leadconnectorhq.com/hooks/YOUR_CONTACT_HOOK_ID

# ── Garage Admin API key (used by outbox route auth) ──
GARAGE_ADMIN_API_KEY=dev-intake-key-change-me

# ── Optional reviews ──
NEXT_PUBLIC_REVIEW_RATING=4.9
NEXT_PUBLIC_REVIEW_COUNT=200
NEXT_PUBLIC_REVIEW_BEST=5

# ── Optional hours ──
NEXT_PUBLIC_HOURS_MON_FRI=08:00-18:00
NEXT_PUBLIC_HOURS_SAT=08:00-18:00
NEXT_PUBLIC_HOURS_SUN=09:00-18:00
