  "private": true,
  "scripts": {
    "dev": "next dev --port 3002",
    "build": "prisma generate --schema=../../prisma/schema.prisma && next build",
    "start": "next start",
    "lint": "next lint",
    "outbox": "npx tsx scripts/process-outbox.ts",
