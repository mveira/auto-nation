# ── Database (Supabase Postgres) ──────────────────────────────────────────
# Required for all environments
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# ── Auth ─────────────────────────────────────────────────────────────────
# Change in production!
JWT_SECRET=change-me-to-a-random-64-char-string

# ── Intake API (called by services-web) ──────────────────────────────────
# Must match GARAGE_ADMIN_API_KEY in services-web .env.local
INTAKE_API_KEY=dev-intake-key-change-me

# Default client slug (for single-tenant setup)
DEFAULT_CLIENT_SLUG=car-nation-bristol

# ── GHL Private Integration ──────────────────────────────────────────────
# Required for CRM sync (outbox processor)
# GHL_PRIVATE_TOKEN=your-ghl-private-integration-token
# GHL_LOCATION_ID=your-ghl-location-id
# GHL_PIPELINE_ID=your-ghl-pipeline-id

# GHL stage ID mapping (map internal statuses to GHL pipeline stage IDs)
# GHL_STAGE_NEW=stage-id-for-new
# GHL_STAGE_CONTACTED=stage-id-for-contacted
# GHL_STAGE_BOOKED=stage-id-for-booked
# GHL_STAGE_IN_PROGRESS=stage-id-for-in-progress
# GHL_STAGE_COMPLETE=stage-id-for-complete
# GHL_STAGE_LOST=stage-id-for-lost

# ── App URL ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_URL=http://localhost:3002
